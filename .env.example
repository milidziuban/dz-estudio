# Copiar a .env y completar con los valores reales (Supabase → Settings → API)
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Google Analytics 4 (opcional). Sin este valor, el tracking queda desactivado.
VITE_GA_ID=G-XXXXXXXXXX

# Dominio del sitio en producción (para canonical, OG tags y SEO).
# En desarrollo se puede omitir.
VITE_SITE_URL=https://tu-dominio.vercel.app
